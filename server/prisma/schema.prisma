generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model FavoriteRoute {
  id              String   @id @default(uuid())
  userId          String
  customName      String
  latitude        Float
  longitude       Float
  originalAddress String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
