generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model FavoriteRoute {
  id              String   @id @default(uuid())
  userId          String
  customName      String
  latitude        Float
  longitude       Float
  originalAddress String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("favorite_routes")
}

model TrafficLight {
  id        Int      @id @default(autoincrement())
  name      String
  lat       Float
  lng       Float
  green     Int
  red       Int
  start     DateTime
  heading   Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("traffic_lights")
}
